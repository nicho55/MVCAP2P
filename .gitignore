# artefatos de build do Rust
/target

# binários e pacotes de distribuição (vão como GitHub Release, não no Git)
/dist/tabletop
/dist/signaling
/dist/logo.svg
*.tar.gz

# screenshots de teste (mas mantém os SVGs de assets)
/*.png
/screenshot_*.png

# sccache/local
.env
/.claude/

# opencode config (contém API keys)
opencode.json

# Android SDK (enorme, não versionar)
/Sdk/

# Android build artifacts (todos os níveis)
/app/android/.gradle/
/app/android/app/build/
*.apk
*.aab
*.dex

# Build temporário
/build/
/build/tmp/

# Node / docs build
/docs/node_modules/
/docs/.next/
/docs/out/

# Artefatos locais (config específica de máquina — Android SDK/NDK path)
*.local.properties
local.properties
app/android/local.properties

# lib nativa Rust (regenerada por cargo-ndk a cada build)
/app/android/app/src/main/jniLibs/*/libtabletop.so
